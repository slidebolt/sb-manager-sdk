# Shared local stack environment for sb-manager-sdk tests.
# Copy to .env.local and fill in your real local values.

# plugin-amcrest
AMCREST_HOST=192.168.1.10
AMCREST_USERNAME=admin
AMCREST_PASSWORD=change-me
AMCREST_SCHEME=http
AMCREST_TIMEOUT_MS=3000

# plugin-androidtv
ANDROIDTV_DISCOVERY_TIMEOUT_MS=1000

# plugin-zigbee2mqtt
Z2M_MQTT_BROKER=tcp://localhost:1883
Z2M_MQTT_USERNAME=
Z2M_MQTT_PASSWORD=
Z2M_DISCOVERY_PREFIX=homeassistant
Z2M_BASE_TOPIC=zigbee2mqtt
Z2M_CLIENT_ID=slidebolt-z2m-plugin

# plugin-esphome
ESPHOME_API_KEY=replace-with-api-key
ESPHOME_USERNAME=admin
ESPHOME_PASSWORD=replace-with-password
ESPHOME_DASHBOARD_URL=https://example.local/

# plugin-frigate
FRIGATE_URL=http://127.0.0.1:5000
FRIGATE_GO2RTC_URL=http://127.0.0.1:1984
# FRIGATE_MQTT_HOST=
# FRIGATE_MQTT_PORT=1883
# FRIGATE_MQTT_USER=
# FRIGATE_MQTT_PASSWORD=
# FRIGATE_MQTT_TOPIC_PREFIX=frigate

# plugin-kasa
KASA_SUBNET=192.168.1
KASA_TIMEOUT_MS=400
KASA_DISCOVERY_CONCURRENCY=64

# plugin-wiz
WIZ_SUBNET=192.168.1
WIZ_TIMEOUT_MS=500
